# Fichier .env.example — UMC Interface Web Symfony
# Ce fichier est un modèle : il ne contient aucun identifiant réel.
# Pour utiliser le projet, il faut :
# Copier ce fichier : cp .env.example .env
# Remplir les vraies valeurs dans .env
# Ne pas committer le fichier .env sur GitHub


# Environnement Symfony
# dev   = développement local (erreurs détaillées, cache désactivé)
# prod  = production (erreurs masquées, cache activé)
APP_ENV=dev

# Active ou désactive le mode débogage (true en dev, false en prod pour sécurité)
APP_DEBUG=true

# Clé secrète Symfony génère une nouvelle avec :
# php bin/console secrets:generate-keys
APP_SECRET=CHANGER_CETTE_VALEUR_AVEC_UNE_CLE_ALEATOIRE


# Base de données MariaDB distante (Alwaysdata) 
# Format : mysql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_BDD?options
# Alwaysdata :
#   HOTE = mysql-NOMDUCOMPTE.alwaysdata.net
#   PORT = 3306
#   UTILISATEUR = login Alwaysdata
#   NOM_BDD = nom de la base créée dans le tableau de bord
#
# Exemple pour Alwaysdata :
# DATABASE_URL="mysql://UTILISATEUR:MOT_DE_PASSE@mysql-NOMDUCOMPTE.alwaysdata.net:3306/NOM_BDD?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="mysql://UTILISATEUR:MOT_DE_PASSE@HOTE:3306/NOM_BDD?serverVersion=10.11.2-MariaDB&charset=utf8mb4"


# Envoi d'emails (Symfony Mailer) :
# À configurer pour activer le formulaire de contact.
# Option Alwaysdata SMTP :
# MAILER_DSN=smtp://UTILISATEUR:MOT_DE_PASSE@smtp-NOMDUCOMPTE.alwaysdata.net:587
#
# Option Gmail (mot de passe d'application requis) :
# MAILER_DSN=gmail://ADRESSE_GMAIL:MOT_DE_PASSE_APPLICATION@default
#
# Laisser vide pour désactiver l'envoi d'emails
MAILER_DSN=


# Messenger 
# Utilisé par Symfony pour les tâches asynchrones
# Laisser en doctrine par défaut
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

