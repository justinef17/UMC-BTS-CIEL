            <h5 class="fw-bold text-success mb-1">TRIDIMENSION</h5>
            <p class="text-muted small mb-2">3 impasse du Grand Jardin, 35400 Saint-Malo</p>
            <p class="small mb-2"><i class="bi bi-telephone-fill text-success me-1"></i> 02 99 81 12 02</p>
            <p class="small mb-3"><i class="bi bi-envelope-fill text-success me-1"></i> contact@tridimension.fr</p>
            <div class="d-flex gap-2 flex-wrap">
              <a href="https://tridimension.fr/" target="_blank" class="btn btn-success btn-sm">
                <i class="bi bi-globe me-1"></i> tridimension.fr
              </a>
              <a href="https://www.linkedin.com/company/tridimension/" target="_blank" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-linkedin me-1"></i> LinkedIn
              </a>
              <a href="https://www.linkedin.com/in/jean-michel-jolivet-99522357/" target="_blank" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-linkedin me-1"></i> LinkedIn : directeur Jean-Michel Jolivet
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    {# PROFESSEURS RÉFÉRENTS #}
    <div class="row mb-5">
      <div class="col-12">
        <h2 class="fw-bold text-success border-bottom border-success border-2 pb-2 mb-4">Professeurs référents</h2>
      </div>

      <div class="col-md-6 col-lg-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center py-4">
            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
              <i class="bi bi-person-fill text-success fs-3"></i>
            </div>
            <h5 class="fw-bold mb-1">Thierry Lafferière</h5>
            <p class="text-muted small mb-1">Enseignant BTS CIEL</p>
            <p class="text-muted small mb-3">Lycée Maupertuis - Saint-Malo</p>
            <a href="https://www.linkedin.com/in/thierry-lafferri%C3%A8re-8ba005162/" target="_blank" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-linkedin me-1"></i> LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center py-4">
            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
              <i class="bi bi-person-fill text-success fs-3"></i>
            </div>
            <h5 class="fw-bold mb-1">Patrick Bazin</h5>
            <p class="text-muted small mb-1">Enseignant BTS CIEL</p>
            <p class="text-muted small mb-3">Lycée Maupertuis - Saint-Malo</p>
          </div>
        </div>
      </div>
    </div>

    {# ÉQUIPE ÉTUDIANTE #}
    <div class="row mb-5">
      <div class="col-12">
        <h2 class="fw-bold text-success border-bottom border-success border-2 pb-2 mb-4">Équipe projet — BTS CIEL 2024-2026</h2>
      </div>

      <div class="col-md-6 col-lg-3 mb-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center py-4">
            <div class="bg-success rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold fs-4 mb-3" style="width:64px;height:64px;">A</div>
            <h5 class="fw-bold mb-1">Justine Friant</h5>
            <span class="badge bg-success-subtle text-success border border-success mb-2">Interface web & Symfony & VPS OVH</span>
            <p class="text-muted small mb-3">BTS CIEL — Lycée Maupertuis</p>
            <a href="https://www.linkedin.com/in/justine-friant-004642331/" target="_blank" class="btn btn-outline-primary btn-sm w-100">
              <i class="bi bi-linkedin me-1"></i> LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-3 mb-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center py-4">
            <div class="bg-success rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold fs-4 mb-3" style="width:64px;height:64px;">B</div>
            <h5 class="fw-bold mb-1">Raphaël Houde-Hamelin</h5>
            <span class="badge bg-success-subtle text-success border border-success mb-2">SFTP & VPS OVH</span>
            <p class="text-muted small mb-3">BTS CIEL — Lycée Maupertuis</p>
            <a href="https://www.linkedin.com/in/raph-h-profil/" target="_blank" class="btn btn-outline-primary btn-sm w-100">
              <i class="bi bi-linkedin me-1"></i> LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-3 mb-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body text-center py-4">
            <div class="bg-success rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold fs-4 mb-3" style="width:64px;height:64px;">C</div>
            <h5 class="fw-bold mb-1">Théo Thébault</h5>
            <span class="badge bg-success-subtle text-success border border-success mb-2">Raspberry Pi & MariaDB</span>
            <p class="text-muted small mb-3">BTS CIEL — Lycée Maupertuis</p>
          </div>
        </div>
      </div>
    </div>

    {# FORMULAIRE DE CONTACT SÉCURISÉ #}
    <div class="row">
      <div class="col-12">
        <h2 class="fw-bold text-success border-bottom border-success border-2 pb-2 mb-4">Nous contacter</h2>
      </div>

      <div class="col-lg-7 mb-4">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-4">

            {% if success %}
              <div class="alert alert-success" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> Votre message a bien été envoyé. Merci !
              </div>
            {% endif %}

            <form method="post" action="{{ path('app_contact') }}" novalidate>
              <input type="hidden" name="_token" value="{{ csrf_token('contact_form') }}">

              <div class="mb-3">
                <label for="nom" class="form-label fw-semibold">Nom complet <span class="text-danger">*</span></label>
                <input type="text" class="form-control {% if errors.nom is defined %}is-invalid{% endif %}"
                       id="nom" name="nom" value="{{ formData.nom }}" placeholder="Jean Dupont" maxlength="100">
                {% if errors.nom is defined %}
                  <div class="invalid-feedback">{{ errors.nom }}</div>
                {% endif %}
              </div>

              <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Adresse email <span class="text-danger">*</span></label>
                <input type="email" class="form-control {% if errors.email is defined %}is-invalid{% endif %}"
                       id="email" name="email" value="{{ formData.email }}" placeholder="jean.dupont@email.fr">
                {% if errors.email is defined %}
                  <div class="invalid-feedback">{{ errors.email }}</div>
                {% endif %}
              </div>

              <div class="mb-3">
                <label for="sujet" class="form-label fw-semibold">Sujet</label>
                <select class="form-select" id="sujet" name="sujet">
                  <option value="">-- Choisir un sujet --</option>
                  <option value="Question sur le projet UMC" {% if formData.sujet == 'Question sur le projet UMC' %}selected{% endif %}>Question sur le projet UMC</option>
                  <option value="Partenariat / Collaboration" {% if formData.sujet == 'Partenariat / Collaboration' %}selected{% endif %}>Partenariat / Collaboration</option>
                  <option value="Données & Téléchargement" {% if formData.sujet == 'Données & Téléchargement' %}selected{% endif %}>Données & Téléchargement</option>
                  <option value="Autre" {% if formData.sujet == 'Autre' %}selected{% endif %}>Autre</option>
                </select>
              </div>

              <div class="mb-4">
                <label for="message" class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
                <textarea class="form-control {% if errors.message is defined %}is-invalid{% endif %}"
                          id="message" name="message" rows="5" maxlength="2000"
                          placeholder="Votre message…">{{ formData.message }}</textarea>
                {% if errors.message is defined %}
                  <div class="invalid-feedback">{{ errors.message }}</div>
                {% endif %}
              </div>

              <button type="submit" class="btn btn-success fw-semibold px-4">
                <i class="bi bi-send-fill me-2"></i> Envoyer le message
              </button>

              {# Mention RGPD #}
              <div class="mt-3 p-3 bg-light border border-success-subtle rounded">
                <p class="text-muted small mb-0">
                  <i class="bi bi-shield-lock-fill text-success me-1"></i>
                  <strong>Protection de vos données (RGPD) :</strong>
                  Les données saisies dans ce formulaire (nom, email, message) sont transmises
                  uniquement par email à l'équipe TRIDIMENSION afin de traiter votre demande.
                  <strong>Aucune donnée n'est stockée sur ce site !</strong> 
                  Elles sont automatiquement supprimées après l'envoi. Seul le destinataire de l'email
                  a accès à vos informations. Pour exercer vos droits d'accès,
                  de rectification ou de suppression auprès de TRIDIMENSION, contactez :
                  <a href="mailto:contact@tridimension.fr" class="text-success fw-semibold">
                    contact@tridimension.fr
                  </a>
                </p>
              </div>

            </form>
          </div>
        </div>
      </div>

      {# Infos rapides #}
      <div class="col-lg-5 mb-4">
        <div class="card border-success border-2 shadow-sm h-100">
          <div class="card-body p-4">
            <h5 class="fw-bold text-success mb-4">Informations utiles</h5>

            <div class="d-flex gap-3 mb-3">
              <div class="text-success fs-4 flex-shrink-0"><i class="bi bi-geo-alt-fill"></i></div>
              <div>
                <div class="fw-semibold small">Adresse</div>
                <div class="text-muted small">Lycée Maupertuis<br>Saint-Malo, Bretagne</div>
              </div>
            </div>

            <div class="d-flex gap-3 mb-3">
              <div class="text-success fs-4 flex-shrink-0"><i class="bi bi-globe"></i></div>
              <div>
                <div class="fw-semibold small">Site du lycée</div>
                <a href="https://www.lyceemaupertuis.bzh/" target="_blank" class="text-success small">www.lyceemaupertuis.bzh</a>
              </div>
            </div>

            <div class="d-flex gap-3 mb-3">
              <div class="text-success fs-4 flex-shrink-0"><i class="bi bi-building"></i></div>
              <div>
                <div class="fw-semibold small">Partenaire</div>
                <a href="https://tridimension.fr/" target="_blank" class="text-success small">tridimension.fr</a>
              </div>
            </div>

            <div class="d-flex gap-3">
              <div class="text-success fs-4 flex-shrink-0"><i class="bi bi-linkedin"></i></div>
              <div>
                <div class="fw-semibold small">LinkedIn Tridimension</div>
                <a href="https://www.linkedin.com/company/tridimension/" target="_blank" class="text-success small">linkedin.com/company/tridimension</a>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>

{% endblock %}